# Defconfig fragment applied on top of arch/arm64/configs/defconfig for the
# Pixel Fold (felix, GS201) build. Merged via scripts/kconfig/merge_config.sh
# in the repo-root Makefile's .build_kernel target.
#
# GS201 is built on Cortex-X1/A78/A55 cores — ARMv8.2-era silicon with a few
# ARMv8.4 bits. Mainline defconfig enables many newer architectural features
# (LPA2, BTI, MTE, POE, GCS, SME, HAFT) that assume ARMv8.5+ or ARMv8.7+.
# Most are runtime-detected and would simply sit unused on GS201, but
# ARM64_LPA2 + VA_BITS_52 change MMU setup in head.S and can cause a silent
# hang before earlycon is up. Force VA=48 and disable the optional extensions
# to keep head.S on a path the CPU actually implements.

# 48-bit VA, disable 52-bit VA + LPA2.
# CONFIG_ARM64_VA_BITS_52 is not set
CONFIG_ARM64_VA_BITS_48=y
# CONFIG_ARM64_PA_BITS_52 is not set
# CONFIG_ARM64_LPA2 is not set

# Disable ARMv8.5+ / ARMv9 features absent on GS201 (Cortex-X1/A78/A55).
# CONFIG_ARM64_BTI is not set
# CONFIG_ARM64_BTI_KERNEL is not set
# CONFIG_ARM64_MTE is not set
# CONFIG_ARM64_POE is not set
# CONFIG_ARM64_EPAN is not set
# CONFIG_ARM64_HAFT is not set
# CONFIG_ARM64_GCS is not set
# CONFIG_ARM64_SME is not set

# Dial NR_CPUS down from the mainline default (64) to match the 8 cores
# GS201 actually has — saves a bit of memory on various per-cpu structures.
CONFIG_NR_CPUS=8

# pstore/ramoops: capture panics + console + userspace pmsg into the 4 MiB
# reserved region declared by ramoops_mem@fd3ff000 in gs201-android-handoff.dtsi
# (2 MiB console-size + 2 MiB pmsg-size + ~remainder for dmesg-ramoops).
# PSTORE_RAM is built in (=y, not =m) so the backend is wired up before any
# module loader runs — otherwise a very early panic between MMU bring-up and
# rootfs mount would never reach the ramoops buffer. CONSOLE captures the
# kmsg stream (so we get kernel printk across reboot, not just panic dmesg);
# PMSG opens /dev/pmsg0 for userspace beacons.
CONFIG_PSTORE_RAM=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_PMSG=y

# Allow /dev/mem reads of System-RAM-mapped regions. The ramoops carveout at
# 0xfd3ff000 is declared `map` (not `nomap`) in gs201-android-handoff.dtsi, so
# the kernel includes it in System RAM. With STRICT_DEVMEM=y, /dev/mem refuses
# reads of System RAM addresses, blocking any out-of-band inspection of the
# ramoops region. We need to peek at the raw bytes to disambiguate "panic
# wrote, but next-boot scan rejected the header" (region has data, wrong sig)
# from "DRAM was wiped by the master-disconnect reboot path" (region all
# zeros). Disabling STRICT_DEVMEM is a debug-only relaxation; safe to flip
# back on once the ramoops persistence question is settled.
# CONFIG_STRICT_DEVMEM is not set

# Enable dynamic_debug so we can flip on dwc3 / phy-exynos5-usbdrd pr_debug
# output at runtime via /sys/kernel/debug/dynamic_debug/control. Phase A
# USB host-side enumeration is failing with EPROTO and we need IRQ-by-IRQ
# trace data to root-cause the EP0 control-transfer issue.
CONFIG_DYNAMIC_DEBUG=y
CONFIG_DYNAMIC_DEBUG_CORE=y

# NOTE 2026-05-06: CONFIG_FTRACE was tried to capture dwc3 tracepoints but
# enabling it caused serial-getty@ttySAC0 to never render its login prompt
# (tracepoint instrumentation appears to perturb samsung_tty termios timing
# enough to break agetty's terminal-size probe). Reverted. To get dwc3
# IRQ-level diagnostics now, use targeted pr_info() patches in
# drivers/usb/dwc3/ directly.
# CONFIG_FTRACE is not set

# Phase G.9 USB SETUP-delivery investigation: probe-only stub for the gs201
# S2MPU (Stage-2 MPU) instances. Tests whether ATF/firmware power-domain
# transitions key off the kernel having claimed the s2mpu_hsi0 device.
CONFIG_GS201_S2MPU_STUB=y
