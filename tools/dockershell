#!/usr/bin/env bash
# Run a command inside an ephemeral build container with the repo bind-mounted.
#
# Usage:
#   tools/dockershell                  # interactive shell
#   tools/dockershell just all         # run the build
#   tools/dockershell fastboot devices # talk to a connected device
#   tools/dockershell tio /dev/ttyUSB0 # serial console
#   tools/dockershell setup            # one-time host: register aarch64 binfmt
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE="${JUNKYARD_IMAGE:-junkyard-build}"
DOCKERFILE="$REPO_ROOT/tools/Dockerfile"

# Mount the repo at its REAL path, not /work, and drag in the owning gitdir when
# this is a worktree checkout.
#
# A worktree keeps its git state outside the tree, reached by a chain that mixes
# absolute and relative paths in both directions:
#
#   .git                     -> gitdir: /abs/…/<owner>/.git/worktrees/<name>
#   kernel/source/.git       -> gitdir: ../../../<owner>/.git/worktrees/…       (escapes the repo)
#   …/worktrees/…/source     -> ../../../../../../../<repo>/kernel/source        (points back)
#
# No single mount point satisfies all three, and mounting at /work satisfies
# none — so git fails inside the container. That broke `clone_kernel_source`
# outright (exit 128) and, far more quietly, made scripts/setlocalversion fall
# back to the bare tag: kernel_version came out `7.2.0-rc4` instead of
# `7.2.0-rc4-00112-gc39947346ac6`. A kernel whose uname -r cannot identify the
# build is a debugging trap, so keep the host layout intact here.
mount_args=(-v "$REPO_ROOT:$REPO_ROOT")
if [ -f "$REPO_ROOT/.git" ]; then
  _gitdir="$(sed -n 's/^gitdir: //p' "$REPO_ROOT/.git")"
  case "$_gitdir" in
    /*) _owner="${_gitdir%%/.git/*}" ;;                      # absolute -> owning repo root
    *)  _owner="$(cd "$REPO_ROOT/${_gitdir%%/.git/*}" && pwd)" ;;
  esac
  if [ -n "${_owner:-}" ] && [ -d "$_owner" ] && [ "$_owner" != "$REPO_ROOT" ]; then
    mount_args+=(-v "$_owner:$_owner")
  fi
fi

if [ "${1:-}" = "setup" ]; then
  echo "Registering aarch64 binfmt on the host kernel (one-time)..." >&2
  exec docker run --privileged --rm tonistiigi/binfmt --install arm64
fi

# Rebuild image if missing or older than the Dockerfile.
need_build=1
if docker image inspect "$IMAGE" >/dev/null 2>&1; then
  img_created=$(date -d "$(docker image inspect -f '{{.Created}}' "$IMAGE")" +%s)
  df_mtime=$(stat -c %Y "$DOCKERFILE")
  [ "$img_created" -gt "$df_mtime" ] && need_build=0
fi
if [ "$need_build" -eq 1 ]; then
  docker build \
    --build-arg USER_UID="$(id -u)" \
    --build-arg USER_GID="$(id -g)" \
    -t "$IMAGE" \
    -f "$DOCKERFILE" \
    "$REPO_ROOT/tools" >&2
fi

# Pass through serial adapters and the USB bus. Bind-mount /dev/bus/usb as a
# directory (rather than --device) so devices that re-enumerate into bootloader
# mode stay visible to the container without restart.
device_args=()
for tty in /dev/ttyUSB* /dev/ttyACM*; do
  [ -e "$tty" ] && device_args+=(--device="$tty")
done
[ -d /dev/bus/usb ] && device_args+=(-v /dev/bus/usb:/dev/bus/usb)

tty_args=(-i)
[ -t 0 ] && tty_args+=(-t)

[ $# -eq 0 ] && set -- bash

# systemd-nspawn (used by the Makefile's debootstrap / install-packages /
# install-kernel / install-initramfs stages) needs a system dbus to register
# with. Docker containers don't run dbus by default, so start one inside
# /run/dbus before exec'ing the user's command. Idempotent — a no-op once
# the socket already exists.
exec docker run --rm \
  "${tty_args[@]}" \
  --privileged \
  --cgroupns=host \
  "${mount_args[@]}" \
  -w "$REPO_ROOT" \
  ${device_args[@]+"${device_args[@]}"} \
  --entrypoint /usr/bin/env \
  "$IMAGE" \
  bash -c '
    if [ ! -S /run/dbus/system_bus_socket ]; then
      sudo mkdir -p /run/dbus
      sudo dbus-daemon --system --fork --nopidfile 2>/dev/null
    fi
    exec "$@"
  ' -- "$@"
