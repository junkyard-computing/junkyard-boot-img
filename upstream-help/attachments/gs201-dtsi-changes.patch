+	/*
+	 * UFS device VCC enable. The KIOXIA THGJFGT1E45BAIPB's main power
+	 * rail is gated by gpp0-1 on felix; the bootloader drives it high to
+	 * talk to the device, then drops it during shutdown ("[I] [UFS]
+	 * shutdown complete"). Without this regulator, the kernel's UFS
+	 * driver sees a powered-down device — link startup completes (host
+	 * PHY has independent power) but every NOP OUT response slot stays
+	 * at 0 because the device chip isn't running. Matches AOSP's
+	 * gs201-ufs.dtsi ufs_fixed_vcc.
+	 */
+	ufs_fixed_vcc: regulator-ufs-vcc {
+		compatible = "regulator-fixed";
+		regulator-name = "ufs-vcc";
+		gpio = <&gpp0 1 GPIO_ACTIVE_HIGH>;
+		enable-active-high;
+		/*
+		 * Deliberately omit regulator-boot-on. The bootloader's
+		 * `[I] [UFS] shutdown complete` drops VCC before handing
+		 * off, so when the kernel boots the rail is OFF. With
+		 * regulator-boot-on, the framework would think it's
+		 * already on and skip the GPIO drive when UFS calls
+		 * regulator_enable. Without it, the framework runs the
+		 * fixed-voltage enable path and gpiod_set_value actually
+		 * drives gpp0-1 high.
+		 *
+		 * Power-on settling time. UFS device VCC needs to be
+		 * stable before the host issues commands; without this
+		 * the link comes up but NOP OUT can race the device's
+		 * internal init.
+		 */
+		startup-delay-us = <2000>;
+		pinctrl-names = "default";
+		pinctrl-0 = <&ufs_vcc_en>;
+	};
+
 	ufs_0: ufs@14700000 {
 		compatible = "google,gs201-ufs";
 		reg = <0x0 0x14700000 0x200>,   /* HCI standard  */
