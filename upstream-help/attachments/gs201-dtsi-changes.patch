  *
  * Copyright 2026 Google LLC
  *
- * This DTSI covers the subset of GS201 hardware required for a
- * headless mainline Linux system: interrupt controller, timers, PSCI,
- * ACPM/clocks, pinctrl, serial console, UFS storage, USB, and the
- * Mali-G710 GPU via the Panthor driver.
+ * Two non-obvious things about gs201:
  *
- * TODO: A GS201 CMU (Clock Management Unit) driver is not yet written.
- * UFS and USB peripheral clocks are supplied as fixed-rate stubs
- * (matching the frequencies the Android bootloader programmes) until
- * proper CMU drivers are contributed.  GPU DVFS clocks are ACPM-based
- * and work without the CMU driver.
+ * 1. BL31 firewalls EL1 CMU access UNLESS the kernel boots with
+ *    `kvm-arm.mode=protected` (Makefile sets this). With pKVM disabled,
+ *    direct readl of CMU_TOP @ 0x1e080000 aborts with synchronous external
+ *    abort code 0x96000010. See memory/project_pkvm_cmu_unlock.md.
+ *
+ * 2. Even with CMU access unlocked, mainline `clk-gs101.c` is not
+ *    register-layout compatible with gs201: many CMU_TOP and CMU_HSI2
+ *    register offsets differ from gs101 (AOSP cal-if `cmucal-sfr.c` has
+ *    the gs201-correct map; e.g. SHARED0_DIV4 is at 0x1930 on gs201 vs
+ *    0x1908 on gs101, HSI2_BUS/MMC_CARD are swapped, etc.). Until a
+ *    proper gs201 clock driver exists, UFS/peripheral clocks stay on
+ *    fixed-rate stubs that report the bootloader-programmed rates.
+ *    Hardware is already running at the right rate; the kernel just
+ *    can't reprogram it without the correct offsets.
  */
 
+#include <dt-bindings/clock/google,gs101.h>
 #include <dt-bindings/clock/google,gs201-acpm.h>
 #include <dt-bindings/gpio/gpio.h>
 #include <dt-bindings/interrupt-controller/arm-gic.h>
@@ -265,12 +272,22 @@ oscclk: osc-clock {
 	};
 
 	/*
-	 * Stub fixed-rate clocks for UFS until google,gs201-cmu-hsi2 driver
-	 * is written.  Rates match what the Android bootloader configures:
-	 *   aclk / core_clk  : 267 MHz
-	 *   unipro mclk      : 333 MHz (HS-G4 mode)
-	 * The UFS controller uses these values for timing calculations only;
-	 * the actual hardware clocks are pre-configured by the bootloader.
+	 * Fixed-rate stubs for UFS — see top-of-file note about gs201
+	 * CMU register offsets being incompatible with mainline clk-gs101.
+	 * Rates back-computed from raw CMU_TOP register reads on a real
+	 * boot using gs201-correct offsets (see git history for the probe):
+	 *
+	 *   PLL_CON3_PLL_SHARED0 = 0xa15b0400
+	 *     → M=347, P=4, S=0 → 24.576MHz * 347/4/1 = 2,131,968,000 Hz
+	 *   shared0_div4 = 2131968000 / 4 = 532,992,000 Hz
+	 *   MUX_HSI2_UFS_EMBD = 1 (selects shared0_div4)
+	 *   DIV_HSI2_UFS_EMBD = 2 (divides by 3)
+	 *     → mclk_rate = 532992000 / 3 = 177,664,000 Hz
+	 *
+	 * ufs_aclk's actual rate would come from HSI2_NOC (gs201's "BUS"
+	 * divider, at offset 0x189c — different from gs101's 0x1898 which
+	 * holds MMC_CARD on gs201). Not yet measured; leaving at the
+	 * driver's PCLK_AVAIL_MAX as a known-in-range value.
 	 */
 	ufs_aclk: ufs-aclk {
 		compatible = "fixed-clock";
@@ -281,14 +298,7 @@ ufs_aclk: ufs-aclk {
 	ufs_unipro: ufs-unipro-clk {
