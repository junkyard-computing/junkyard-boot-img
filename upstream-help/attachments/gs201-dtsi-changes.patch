@@ -518,6 +528,36 @@ pinctrl_4: pinctrl@10840000 {
 		#gpio-cells = <2>;
 		interrupt-controller;
 		#interrupt-cells = <2>;
+
+		/*
+		 * gpp0 bank — used for the UFS device's VCC enable pin
+		 * (gpp0-1, see ufs_fixed_vcc below). The Samsung pinctrl
+		 * driver requires explicit bank subnodes; without this,
+		 * `<&gpp0 1 0>` won't resolve and ufs_fixed_vcc fails to
+		 * register, leaving the UFS chip unpowered.
+		 */
+		gpp0: gpp0-gpio-bank {
+			gpio-controller;
+			#gpio-cells = <2>;
+			interrupt-controller;
+			#interrupt-cells = <2>;
+		};
+
+		/*
+		 * Force gpp0-1 into GPIO output function so the
+		 * ufs_fixed_vcc regulator can actually drive the UFS
+		 * device's VCC enable line. Mainline Samsung pinctrl
+		 * doesn't automatically switch the pin's alt-function
+		 * when a consumer requests it as a GPIO; without an
+		 * explicit pin-function = 0 entry, the bootloader's
+		 * leftover function (or POR default) stays selected and
+		 * gpio_set_value writes never reach the pad.
+		 */
+		ufs_vcc_en: ufs-vcc-en {
+			samsung,pins = "gpp0-1";
+			samsung,pin-function = <0>;
+			samsung,pin-pud = <0>;
+		};
 	};
 
 	/* 5: GPIO_PERIC1 */
@@ -562,6 +602,53 @@ pinctrl_8: pinctrl@14460000 {
 		#gpio-cells = <2>;
 		interrupt-controller;
 		#interrupt-cells = <2>;
+
+		/*
+		 * gph3 bank (2 pins at offset 0x000) — the only bank under
+		 * pinctrl_8. The gs201 pin-controller driver has the layout
+		 * hardcoded (gs201_pin_hsi2ufs[] in pinctrl-exynos-arm64.c),
+		 * but it still needs this subnode to exist so pin references
+		 * like "gph3-0" in the pin-state nodes below can be resolved.
+		 */
+		gph3: gph3-gpio-bank {
+			gpio-controller;
+			#gpio-cells = <2>;
+			interrupt-controller;
+			#interrupt-cells = <2>;
+		};
+
+		/*
+		 * UFS GPIO pin-mux states, consumed by ufs_0's pinctrl-0.
+		 * These belong nested in their owning pin-controller — placing
+		 * them at the root of the tree (as this file originally did)
+		 * makes fw_devlink treat the phandle targets as supplier
