+	arm_smccc_smc(SMC_CMD_FMP_SMU_RESUME, 0, SMU_EMBEDDED, 0, 0, 0, 0, 0, &res);
+	dev_info(dev, "SMC_CMD_FMP_SMU_RESUME(0, SMU_EMBEDDED) -> a0=0x%lx a1=0x%lx\n",
+		 res.a0, res.a1);
+
+	arm_smccc_smc(SMC_CMD_FMP_SMU_DUMP, 0, SMU_EMBEDDED, 0, 0, 0, 0, 0, &res);
